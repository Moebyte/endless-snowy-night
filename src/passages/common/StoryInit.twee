:: StoryInit
<<set $game to GameState.create()>>
<<set $game.visited[passage()] to 1>>
<<set $game.visitedLocations.foyer to 1>>
<<set $game.visitedLocations.grand_hall to 1>>
<<set $game.visitedLocations.dining_room to 1>>
<<set $game.visitedLocations.guest_corridor to 1>>
<<set $returnTarget to 'Start'>>
