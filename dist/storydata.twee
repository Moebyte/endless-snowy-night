:: Common_Characters [utility]
<<setReturnTarget>>
<h2>人物档案</h2>
<p class="system-hint">你目前掌握的人物信息。对外身份默认可见，深层性格、特长与不可告人的秘密需要剧情解锁。</p>

<<set _met = $game.metCharacters || {}>>
<<set _chars = Object.keys(_met).filter(function (k) { return _met[k]; })>>
<<if _chars.length == 0>>
<p>你还没有遇到过可以记录的人。</p>
<<else>>
<<for _i to 0; _i lt _chars.length; _i++>>
<<set _cid = _chars[_i]>>
<<set _p = GameState.PROFILES[_cid]>>
<div class="character-card">
<p><strong><<print _p.name>></strong>，<<print _p.age>> 岁，<<print _p.job>></p>
<p class="character-desc">第一印象：<<print _p.firstImpression>></p>

<<if Game.hasRevealedCharacterAspect(_cid, "personality")>>
<p class="character-desc">性格：<<print _p.personality>></p>
<</if>>
<<if Game.hasRevealedCharacterAspect(_cid, "talent")>>
<p class="character-desc">特长：<<print _p.talent>></p>
<</if>>
<<if Game.hasRevealedCharacterAspect(_cid, "secret") && _p.secret>>
<p class="danger">不能说的秘密：<<print _p.secret>></p>
<</if>>

<<if Game.hasRevealed(_cid, "backstory")>>
<p class="system-hint">已解锁：隐藏背景</p>
<</if>>
<<if Game.hasRevealed(_cid, "identity")>>
<p class="system-hint">已解锁：真实身份</p>
<</if>>
</div>
<</for>>
<</if>>

<div class="choice-list">
[[返回|$returnTarget]]
</div>

:: Common_ClueList [utility]
<<setReturnTarget>>
<<set _clues to Object.keys($game.clues)>>
<h2>线索簿</h2>
<<if _clues.length is 0>>
<p class="muted">你还没有收集到任何线索。</p>
<<else>>
<<for _id range _clues>>
  <p><strong><<print Game.clueName(_id)>></strong></p>
  <p class="muted"><<print Game.clueDesc(_id)>></p>
<</for>>
<</if>>
<p>[[返回|$returnTarget]]</p>



:: Common_DayTransition
<<run Game.visit()>>
<<set _advanced to Game.advanceDay()>>
<<if _advanced>>
<<set _chapter to 'Chapter03_06_Framework'>>
<<else>>
<<set _chapter to 'Chapter0' + $game.day + '_Start'>>
<</if>>
<<goto _chapter>>


:: Common_Inventory [utility]
<<setReturnTarget>>
<<set _inv to Object.keys($game.inventory)>>
<h2>道具栏</h2>
<<if _inv.length is 0>>
<p class="muted">你身上没有任何道具。</p>
<<else>>
<<for _id range _inv>>
  <p><strong><<print Game.itemName(_id)>></strong> × <<print $game.inventory[_id]>></p>
  <p class="muted"><<print GameState.ITEMS[_id].desc>></p>
<</for>>
<</if>>
<p>[[返回|$returnTarget]]</p>



:: Common_Map [utility]
<<setReturnTarget>>
<<run Game.visit()>>
<h2>庄园地图</h2>
<p class="system-hint">这是一座建造在雪山深处的老式庄园。地图上只标记你已经亲自踏足的区域；尚未探索的地方仍笼罩在风雪之中。</p>
<<set _zones to ['main_1f','main_2f','main_3f','east_wing','west_wing','courtyard','underground']>>
<<set _zonePassage to {
  'main_1f':'Map_Main1F',
  'main_2f':'Map_Main2F',
  'main_3f':'Map_Main3F',
  'east_wing':'Map_EastWing',
  'west_wing':'Map_WestWing',
  'courtyard':'Map_Courtyard',
  'underground':'Map_Underground'
}>>
<div class="zone-list">
<<for _i to 0; _i lt _zones.length; _i++>>
<<set _zid to _zones[_i]>>
<<set _zinfo to GameState.ZONES[_zid]>>
<<set _discovered to Game.isZoneDiscovered(_zid)>>
<<if _zid == 'underground' && !Game.hasItem('old_key')>>
<<elseif _discovered>>
<div class="zone-card known">
<h3>_zinfo.name</h3>
<p class="muted">_zinfo.desc</p>
<<set _visitedCount to Game.getVisitedLocationsInZone(_zid).length>>
<<set _totalCount to Game.getLocationsByZone(_zid).length>>
<p class="muted">已探索 _visitedCount / _totalCount。</p>
<<capture _zid>>
<<link "进入" _zonePassage[_zid]>><</link>>
<</capture>>
</div>
<<else>>
<div class="zone-card unknown">
<h3>？？？</h3>
<p class="muted">风雪未散，此处尚未发现。</p>
</div>
<</if>>
<</for>>
</div>
<div class="choice-list">
<<if $returnTarget>>
[[返回|$returnTarget]]
<<else>>
[[返回|Start]]
<</if>>
</div>


:: Common_Memory [utility]
<<setReturnTarget>>
<<set _memories to $game.memories>>
<h2>记忆碎片</h2>
<<if _memories.length is 0>>
<p class="muted">你还没有记录下任何跨循环记忆。</p>
<<else>>
<<for _m range _memories>>
  <p class="muted">第 <<print _m.loop>> 轮 · 第 <<print _m.day>> 天</p>
  <p><<print _m.text>></p>
  <hr>
<</for>>
<</if>>
<p>[[返回|$returnTarget]]</p>



:: Common_NightResolution
/% 夜间结算顺序:
 *   1. 魔术师致幻交换 (沈慎 AI 选两人)
 *   2. 预言家查验 + 信任分享 (方衡 AI)
 *   3. 骑士守卫 (林小满 AI 选守卫对象) / 决斗在白天发动
 *   4. 狼人击杀 (狼队投票 AI)
 *   5. 女巫感知死亡 + 救人/诅咒 AI
 *   6. 机械狼窃取神力判定
 %/
<<set _nightLog to []>>
<<set _knightGuarded to null>>

/ ============ 1. 魔术师致幻 ============ /
<<if Game.isAlive('shen_shen') and Game.magicianSwapsRemaining() > 0>>
<<set _swapA to null>>
<<set _swapB to null>>
<<set _aliveChars to []>>
<<run Game.aliveList()>>
<<for _i to 0; _i lt Game.aliveList().length; _i++>>
<<set _cid to Game.aliveList()[_i]>>
<<if _cid != 'shen_shen' and _cid != 'chen_mo'>>
<<run _aliveChars.push(_cid)>>
<</if>>
<</for>>
<<if _aliveChars.length >= 2>>
<<set _swapA to _aliveChars[Math.floor(Math.random() * _aliveChars.length)]>>
<<set _swapB to null>>
<<for _j to 0; _j lt 10; _j++>>
<<set _cand to _aliveChars[Math.floor(Math.random() * _aliveChars.length)]>>
<<if _cand != _swapA and !Game.wasInLastSwap(_swapA) and !Game.wasInLastSwap(_cand)>>
<<set _swapB to _cand>>
<<break>>
<</if>>
<</for>>
<<if _swapB == null>>
<<for _k to 0; _k lt _aliveChars.length; _k++>>
<<if _aliveChars[_k] != _swapA and !Game.wasInLastSwap(_aliveA)>>
<<set _swapB to _aliveChars[_k]>>
<<break>>
<</if>>
<</for>>
<</if>>
<<if _swapA and _swapB>>
<<run Game.magicianSwap(_swapA, _swapB)>>
<<run _nightLog.push('沈慎发动致幻：' + GameState.PROFILES[_swapA].name + ' 与 ' + GameState.PROFILES[_swapB].name + ' 身份交换')>>
<</if>>
<</if>>
<</if>>

/ ============ 2. 预言家查验 ============ /
<<if Game.isAlive('fang_heng')>>
<<set _prophetTarget to Game.prophetAIGetCheckTarget()>>
<<if _prophetTarget>>
<<set _checkResult to Game.prophetCheck(_prophetTarget)>>
<<run _nightLog.push('方衡查验了 ' + GameState.PROFILES[_prophetTarget].name + '：' + (_checkResult.alignment == 'enemy' ? '敌人' : '盟友'))>>
<<if Game.prophetShouldShare()>>
<<set _shareTarget to Game.prophetAICheckNight()>>
<<if _shareTarget>>
<<set _shareResult to Game.prophetShareInfo(_shareTarget, _prophetTarget)>>
<</if>>
<</if>>
<</if>>
<</if>>

/ ============ 3. 骑士守卫 ============ /
<<if Game.isAlive('lin_xiaoman') and !Game.knightWeakened()>>
<<set _guardTarget to Game.knightAIGetGuardTarget()>>
<<if _guardTarget>>
<<set _guardResult to Game.knightGuard(_guardTarget)>>
<<if _guardResult.ok>>
<<set _knightGuarded to _guardTarget>>
<<run _nightLog.push('林小满守卫了 ' + GameState.PROFILES[_guardTarget].name)>>
<</if>>
<</if>>
<</if>>

/ ============ 4. 狼人击杀 ============ /
<<set _kill to Game.executeWolfKill()>>
<<run Game.setLastWolfKill(_kill)>>
<<run Game.witchSenseDeath()>>
<<run Game.visit()>>

/ ============ 5. 女巫决策 ============ /
<<if Game.isAlive('ye_zhiqiu') and !Game.witchBroken() and Game.witchRemaining() > 0>>
<<set _witchDecision to Game.witchAIDecide()>>
<<else>>
<<set _witchDecision to { action: 'pass' }>>
<</if>>

<<if _witchDecision.action is 'save'>>
<<set _witchSaved to Game.witchRevive(Game.witchGetSensedDeath())>>
<<if _witchSaved.ok>>
/ The witch revived the victim: rewrite the kill result so the narrative
/ takes the "saved_by_witch" branch instead of "new corpse". /
<<set _kill.killed to false>>
<<set _kill.special to 'saved_by_witch'>>
<</if>>
<</if>>
<<if _witchDecision.action is 'curse'>>
<<set _witchCurseTarget to _witchDecision.target>>
<<set _witchCurseResult to Game.witchCurse(_witchCurseTarget)>>
<<set _witchCurseName to GameState.PROFILES[_witchCurseTarget].name>>
<</if>>

<<set _loopToDeath to false>>

<<if _kill.killed>>
<<set _actualName to GameState.PROFILES[_kill.actualTarget].name>>

<<if _kill.friendlyFire>>
<h2>黎明 · 狼人自相残杀</h2>
<p>尖叫声把你惊醒。但当你冲出房间时，看到的场景让所有人困惑。</p>
<<if _kill.mutualKill>>
<p>走廊上有两具尸体：<strong><<print _actualName>></strong>（狼王）和 <strong><<print _kill.killerName>></strong>。他们倒在一起，像是互相撕咬致死。</p>
<blockquote>「狼人怎么会杀自己人？除非——它们被什么东西搞糊涂了。」</blockquote>
<p class="system-hint">狼王 <<print _actualName>> 被同伴误杀，同归于尽。执行者 <<print _kill.killerName>> 也死了。可能是魔术师的交换所致。</p>
<<run Game.changeSan(-5)>>
<<run Game.addMemory('第 ' + $game.loop + ' 轮第 ' + $game.day + ' 天夜间：' + _actualName + ' 和 ' + _kill.killerName + ' 同归于尽。狼人自相残杀！')>>
<<else>>
<p><strong><<print _actualName>></strong> 倒在血泊中。但伤痕不对——这是狼的爪牙。</p>
<p class="system-hint">一只狼被同伴误杀。可能是魔术师的交换所致。</p>
<<run Game.changeSan(-5)>>
<<run Game.addMemory('第 ' + $game.loop + ' 轮第 ' + $game.day + ' 天夜间：' + _actualName + ' 被同伴误杀。')>>
<</if>>

<<elseif _kill.special is 'body_removed'>>
<h2>黎明 · 消失的尸体</h2>
<p><strong><<print _actualName>></strong> 的房间门大开着，但里面没有尸体。只有大量的血迹和拖拽的痕迹，延伸到走廊尽头就消失了。</p>
<p class="danger">尸体被抹除了。没有尸体，就没有证据。女巫即使有还魂之力，也无处施展。</p>
<p class="system-hint"><<print _actualName>> 被杀。清道夫狼抹除了尸体，女巫无法复活。</p>
<<run Game.changeSan(-10)>>
<<run Game.addMemory('第 ' + $game.loop + ' 轮第 ' + $game.day + ' 天夜间：' + _actualName + ' 被杀，尸体被抹除。')>>

<<elseif _kill.special is 'saved_by_witch'>>
<h2>黎明 · 从死亡边缘归来</h2>
<p>你冲向 <strong><<print _actualName>></strong> 的房间，却看到他/她正坐在床边，脸色苍白。</p>
<p>叶知秋站在一旁，放下手中的药瓶：「差一点。」</p>
<p class="system-hint">女巫叶知秋在狼人袭击后救活了 <<print _actualName>>。</p>
<<if _witchSaved.reason is 'broken'>>
<p class="danger">叶知秋靠在墙角，双手抱着头，浑身发抖。她用了最后一次力量——精神已经崩溃了。</p>
<<run Game.revealInfo('ye_zhiqiu', 'witch_exposed')>>
<</if>>
<<run Game.changeSan(5)>>
<<run Game.addMemory('第 ' + $game.loop + ' 轮第 ' + $game.day + ' 天夜间：' + _actualName + ' 被狼人袭击，但叶知秋救活了他/她。')>>

<<elseif _kill.special is 'witch_knight_conflict'>>
<h2>黎明 · 夜色中的混乱</h2>
<p><strong><<print _actualName>></strong> 倒下了。</p>
<p>叶知秋站在走廊另一端，神情复杂：「我去了……但有人先到了。她赶走了我，以为安全了——但狼还在。」</p>
<p class="system-hint">骑士守卫和女巫救人冲突：守卫赶走了女巫，以为目标安全，狼趁机杀人。</p>
<<run Game.changeSan(-15)>>
<<run Game.addMemory('第 ' + $game.loop + ' 轮第 ' + $game.day + ' 天夜间：' + _actualName + ' 被杀。女巫与守卫冲突。')>>

<<elseif _kill.special is 'protected_by_knight'>>
<<run Game.knightReset()>>
<h2>黎明 · 无人死亡</h2>
<p>你冲出房间时，发现林小满靠在走廊的墙上，手里的小刀上有血。她对你点了点头：</p>
<blockquote>林小满：「昨晚有东西想闯进来。我挡住了。」</blockquote>
<p class="system-hint">昨夜无人死亡。林小满的保护奏效了，但她现在很虚弱。</p>
<<run Game.addMemory('第 ' + $game.loop + ' 轮第 ' + $game.day + ' 天夜间：林小满保护了某人，无人死亡。')>>

<<else>>
<h2>黎明 · 新的死者</h2>
<p>尖叫声把你从梦中惊醒。你冲出房间，看到走廊上已经围了一圈人。</p>
<p><strong><<print _actualName>></strong> 倒在自己的房间里。门窗从内部锁死，没有搏斗痕迹。</p>
<p>苏晚检查后摇头：「死亡时间大约在凌晨两点。没有外伤，像是……在睡梦中被某种力量夺走了呼吸。」</p>
<p class="system-hint"><<print _actualName>> 被狼人杀害。</p>

<<if _kill.actualTarget is 'chen_mo'>>
<<set _loopToDeath to true>>
<</if>>

<<if _kill.actualTarget is 'su_wan'>>
<<run Game.changeSan(-20)>>
<p class="danger">苏晚死了。你的手在发抖。你蹲下来，握住她已经冰冷的手。天花板上水渍的形状开始变化。</p>
<p class="system-hint">苏晚的死亡让你遭受重创。理智 -20。</p>
<<elseif _kill.actualTarget is 'jiang_bai'>>
<<run Game.changeSan(-15)>>
<p class="danger">江白死了。你的室友，你的死党。他右手腕上的旧疤在晨光中格外刺眼。</p>
<p class="system-hint">江白的死亡让你遭受重创。理智 -15。</p>
<<else>>
<<run Game.changeSan(-10)>>
<</if>>
<<run Game.addMemory('第 ' + $game.loop + ' 轮第 ' + $game.day + ' 天夜间：' + _actualName + ' 被杀。')>>
<</if>>

<<elseif _kill.special is 'saved_by_witch'>>
<h2>黎明 · 从死亡边缘归来</h2>
<p>你冲出房间，没有发现尸体。但叶知秋的房间灯还亮着。</p>
<p class="system-hint">女巫预感到了死亡，救了某人。无人死亡。</p>
<<run Game.addMemory('第 ' + $game.loop + ' 轮第 ' + $game.day + ' 天夜间：有人被袭击，但叶知秋救了回来。')>>

<<else>>
<<run Game.knightReset()>>
<h2>黎明 · 无人死亡</h2>
<p>走廊很安静。你检查了每一扇门，所有人都还活着。</p>
<p>但你知道，这只是暂时的。狼还在。</p>
<p class="system-hint">昨夜无人死亡。但恐惧不会消失。</p>
<<run Game.addMemory('第 ' + $game.loop + ' 轮第 ' + $game.day + ' 天夜间：无人死亡。')>>
<</if>>

/ 女巫诅咒 /
<<if _witchDecision.action is 'curse' and _witchCurseResult.ok>>
<h3>叶知秋的诅咒</h3>
<p>清晨，你发现 <strong><<print _witchCurseName>></strong> 倒在自己的房间里。没有外伤，没有血迹，只是嘴唇发黑——像是被某种看不见的力量夺走了呼吸。</p>
<p class="system-hint">女巫叶知秋在夜间诅咒了 <<print _witchCurseName>>。诅咒是神力，狼王的反杀能力无法触发。</p>
<<if _witchCurseResult.reason is 'broken'>>
<p class="danger">叶知秋靠在墙角，双手抱着头，浑身发抖。她用了最后一次力量——精神已经崩溃了。</p>
<<run Game.revealInfo('ye_zhiqiu', 'witch_exposed')>>
<</if>>
<<run Game.addMemory('第 ' + $game.loop + ' 轮第 ' + $game.day + ' 天夜间：叶知秋诅咒了 ' + _witchCurseName + '。')>>
<</if>>

/ 神职夜间记录（仅玩家可见，存为记忆，不直接展示身份） /
<<if _nightLog.length > 0>>
<details class="night-log" open>
<summary>夜间暗流（你的轮回记忆）</summary>
<<for _n to 0; _n lt _nightLog.length; _n++>>
<p class="muted"><<print _nightLog[_n]>></p>
<</for>>
</details>
<<run Game.addMemory('第 ' + $game.loop + ' 轮第 ' + $game.day + ' 天夜间暗流：' + _nightLog.join('；'))>>
<</if>>

<<run Game.witchClearSensedDeath()>>
<<run Game.magicianResetDaily()>>
<<if _knightGuarded == null>><<run Game.knightReset()>><</if>>

<<if _loopToDeath>>
<h2>你的死亡</h2>
<p class="danger">你低头看着自己胸口的伤。血从指缝间涌出，温热而黏稠。</p>
<p>视野开始模糊。周围的声音变得遥远——有人在喊你的名字，有人在哭泣。</p>
<p>但你听不太清了。</p>
<p>黑暗从边缘涌来，像是有人慢慢拉上了窗帘。</p>
<p>你知道这不是终点。你知道你会再次醒来。</p>
<p class="system-hint">陈默死亡。轮回即将重置。你将带着这一轮的记忆进入下一轮。</p>
<<run Game.nextLoop()>>
[[进入下一轮回|Chapter02_Start]]
<<else>>
<div class="choice-list">
[[继续新的一天|Common_DayTransition]]
</div>
<</if>>


:: Common_SetReturnTarget [widget]
<<widget "setReturnTarget">>
<<set _prev to previous()>>
<<if _prev && !tags(_prev).includes('utility')>>
<<set $returnTarget to _prev>>
<</if>>
<</widget>>


:: Common_ZoneMap [utility]
<<set _zone to _zoneId>>
<<set _zoneInfo to GameState.ZONES[_zone]>>
<<set _visited to Game.getVisitedLocationsInZone(_zone)>>
<<set _all to Game.getLocationsByZone(_zone)>>
<<set _total to _all.length>>
<<set _found to _visited.length>>
<h2>_zoneInfo.name</h2>
<p class="system-hint">_zoneInfo.desc</p>
<p class="muted">已探索 _found / _total 处。</p>
<div class="location-list">
<<for _i to 0; _i lt _all.length; _i++>>
<<set _loc to _all[_i]>>
<<if Game.hasVisitedLocation(_loc.id)>>
<div class="location-card known">
<h4>_loc.name</h4>
<p class="muted">_loc.desc</p>
</div>
<<else>>
<div class="location-card unknown">
<h4>？？？</h4>
<p class="muted">尚未踏足此处。</p>
</div>
<</if>>
<</for>>
</div>
<div class="choice-list">
[[返回地图|Common_Map]]
<<if $returnTarget && $returnTarget != "Common_Map">>
[[返回剧情|$returnTarget]]
<</if>>
</div>


:: God_Knight
<<run Game.visit()>>
<h2>林小满 · 骑士</h2>
<<if Game.knightDuelOnCooldown() and Game.knightGuardOnCooldown()>>
<p class="danger">林小满虚弱地靠在墙上，决斗和守卫的消耗都还没恢复。她今天和今晚都无法行动。</p>
<div class="choice-list">
[[返回|Start]]
</div>
<<else>>
<p>林小满正在擦拭她的折叠小刀。看到你走近，她挑了挑眉：</p>
<blockquote>林小满：「说吧，是让我去盯着谁，还是直接上去砍人？」</blockquote>
<p class="system-hint">骑士有白天与夜晚两种能力，<strong>各自独立冷却</strong>，互不影响：</p>
<ul>
<li><strong>决斗（白天）</strong>：指认一人为狼。若真是狼则斩杀；若不是则林小满自己死。狼王同归于尽。决斗后次日白天无法再次决斗，但不影响守卫。</li>
<li><strong>守卫（夜晚）</strong>：保护一人，今晚狼人袭击该人时被挡下。不可连续两晚守同一人。守卫后次夜无法再次守卫，但不影响决斗。与女巫救人冲突时互相抵消。</li>
</ul>

<div class="choice-list">
<<if Game.knightDuelOnCooldown()>>
<span class="muted">决斗冷却中（明日可用）</span>
<<else>>
<<link "决斗——指认某人">><<goto 'God_Knight_Duel'>><</link>>
<</if>>
<<if Game.knightGuardOnCooldown()>>
<span class="muted">守卫冷却中（明夜可用）</span>
<<else>>
<<link "守卫——保护某人">><<goto 'God_Knight_Guard'>><</link>>
<</if>>
</div>
<div class="choice-list">
[[算了，不打搅她|Start]]
</div>
<</if>>


:: God_Knight_Duel
<<run Game.visit()>>
<h2>林小满 · 决斗</h2>
<p>林小满握紧小刀：</p>
<blockquote>林小满：「你如果有目标，就告诉我。但我要提醒你——如果我砍错了人，死的会是我。」</blockquote>
<p class="system-hint">骑士决斗：若目标是狼人，斩杀之；若不是，林小满自己死。若目标是狼王，同归于尽。</p>
<p class="warning">决斗后林小满次日白天无法再次决斗，但夜晚仍可守卫。</p>
<div class="choice-list">
<<if Game.isAlive('zhou_yang')>>
<<link "指认周阳是狼">><<run Game.knightDuel('zhou_yang')>><<goto 'God_Knight_Result'>><</link>>
<</if>>
<<if Game.isAlive('tang_xiaotang')>>
<<link "指认唐小棠是狼">><<run Game.knightDuel('tang_xiaotang')>><<goto 'God_Knight_Result'>><</link>>
<</if>>
<<if Game.isAlive('zhao_mingcheng')>>
<<link "指认赵明城是狼">><<run Game.knightDuel('zhao_mingcheng')>><<goto 'God_Knight_Result'>><</link>>
<</if>>
<<if Game.isAlive('gu_yan')>>
<<link "指认顾言是狼">><<run Game.knightDuel('gu_yan')>><<goto 'God_Knight_Result'>><</link>>
<</if>>
</div>
<div class="choice-list">
[[放弃决斗|God_Knight]]
</div>

:: God_Knight_Guard
<<run Game.visit()>>
<h2>林小满 · 守卫</h2>
<<if Game.knightGuardOnCooldown()>>
<p class="danger">林小满虚弱地靠在墙上，上次行动的消耗还没恢复。守卫的消耗还没恢复，今夜无法再守卫（但白天决斗不受影响）。</p>
<div class="choice-list">
[[返回|Start]]
</div>
<<else>>
<p>林小满收起折叠小刀，压低声音：</p>
<blockquote>林小满：「你想让我守着谁？我只能护一个人，而且下一晚不能再守卫——但白天砍人不受影响。你确定？」</blockquote>
<p class="system-hint">守卫：今晚狼人袭击该目标时，林小满会挡下。守卫后次夜无法再次守卫，但白天决斗不受影响。</p>
<p class="warning">守卫与女巫救人冲突时，两者互相抵消，目标仍会死亡。</p>

<div class="choice-list">
<<if Game.isAlive('su_wan')>>
<<link "保护苏晚">><<run Game.knightGuard('su_wan')>><<goto 'God_Knight_Guard_Result'>><</link>>
<</if>>
<<if Game.isAlive('jiang_bai')>>
<<link "保护江白">><<run Game.knightGuard('jiang_bai')>><<goto 'God_Knight_Guard_Result'>><</link>>
<</if>>
<<if Game.isAlive('zheng_shoushan')>>
<<link "保护老郑">><<run Game.knightGuard('zheng_shoushan')>><<goto 'God_Knight_Guard_Result'>><</link>>
<</if>>
<<if Game.isAlive('ye_zhiqiu')>>
<<link "保护叶知秋">><<run Game.knightGuard('ye_zhiqiu')>><<goto 'God_Knight_Guard_Result'>><</link>>
<</if>>
<<if Game.isAlive('fang_heng')>>
<<link "保护方衡">><<run Game.knightGuard('fang_heng')>><<goto 'God_Knight_Guard_Result'>><</link>>
<</if>>
<<if Game.isAlive('shen_shen')>>
<<link "保护沈慎">><<run Game.knightGuard('shen_shen')>><<goto 'God_Knight_Guard_Result'>><</link>>
<</if>>
<<if Game.isAlive('chen_mo')>>
<<link "保护陈默">><<run Game.knightGuard('chen_mo')>><<goto 'God_Knight_Guard_Result'>><</link>>
<</if>>
</div>
<div class="choice-list">
[[算了，返回|God_Knight]]
</div>
<</if>>

:: God_Knight_Guard_Result
<<run Game.visit()>>
<<set _guardResult to $game.godSkills.knight>>
<h2>守卫</h2>
<<set _guardName to GameState.PROFILES[_guardResult.lastGuard].name>>
<p>林小满点了点头，收起小刀：</p>
<blockquote>林小满：「我去盯着 <<print _guardName>> 的房间。今晚不会有东西靠近他/她。」</blockquote>
<p>她的背影消失在走廊拐角。你希望这个决定是对的。</p>
<p class="system-hint">林小满正在守卫 <<print _guardName>>。今夜如果狼人袭击 <<print _guardName>>，林小满会挡下。</p>
<p class="warning">林小满次夜无法再次守卫，但白天决斗不受影响。</p>
<div class="choice-list">
[[返回|Start]]
</div>

:: God_Knight_Result
<<run Game.visit()>>
<<set _result to $game.godSkills.knight>>
<h2>决斗</h2>
<<if not Game.isAlive('lin_xiaoman')>>
<p class="danger">林小满倒下了。她砍错了人，骑士的代价是自己的命。</p>
<blockquote>林小满（最后的话）：「棠棠……对不起……」</blockquote>
<p class="system-hint">林小满死亡。骑士能力消失。好人阵营失去了唯一的武力淘汰手段。</p>
<<else>>
<p>林小满擦掉刀上的血，面无表情地看着倒下的尸体。</p>
<blockquote>林小满：「它果然是狼。干得漂亮，陈默。」</blockquote>
<p class="system-hint">一只狼被斩杀。林小满次日白天无法再次决斗，但夜晚守卫不受影响。</p>
<p class="danger">如果是狼王，林小满会与之同归于尽。</p>
<</if>>
<div class="choice-list">
[[返回|Start]]
</div>


:: God_Magician
<<run Game.visit()>>
<h2>沈慎 · 魔术师</h2>
<<set _remaining to Game.magicianSwapsRemaining()>>
<<set _currentSwap to Game.getMagicianSwap()>>

<p>沈慎坐在壁炉旁的阴影里，手指不停地搓着一张扑克牌。</p>
<blockquote>沈慎：「我可以让两个人在夜里互换身份。狼只会看到交换后的样子。如果它们冲着一个人去……杀的其实是另一个。」</blockquote>
<p class="system-hint">身份交换：选择两人互换，只有夜晚狼人形态能感知。交换在当夜生效，次日重置。每天可用一次。</p>
<p class="warning">限制：不能连续两晚交换同一个人。上一晚参与交换的人今晚无法再被交换。</p>

<<if _currentSwap>>
<p class="warning">今晚已设置交换：<strong><<print GameState.PROFILES[_currentSwap.a].name>></strong> ↔ <strong><<print GameState.PROFILES[_currentSwap.b].name>></strong></p>
<p class="muted">交换已生效，无法更改。</p>
<<else>>
<p>剩余交换次数：<strong><<print _remaining>></strong>/7</p>

<<if _remaining > 0>>
<h3>选择交换的两人</h3>
<div class="choice-list">
<<if Game.isAlive('su_wan') and Game.isAlive('jiang_bai') and not Game.wasInLastSwap('su_wan') and not Game.wasInLastSwap('jiang_bai')>>
